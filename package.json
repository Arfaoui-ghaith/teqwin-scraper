{
  "name": "teqween-scraper-nest",
  "private": true,
  "version": "1.0.0",
  "description": "NestJS API to trigger scrapers and save to PostgreSQL",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start:dev": "ts-node --project tsconfig.json -r tsconfig-paths/register src/main.ts",
    "db:create-tables": "node scripts/create-tables.js",
    "db:add-binary-image": "node scripts/add-binary-image-column.js",
    "db:backfill-binary-images": "node scripts/backfill-company-binary-images.js",
    "db:clear-tanitjobs-images": "node scripts/clear-tanitjobs-company-images.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.3.1",
    "cheerio": "^1.0.0-rc.12",
    "country-in-text-detector": "^1.0.10",
    "dotenv": "^16.0.3",
    "html-entities": "^2.3.3",
    "https-proxy-agent": "^5.0.1",
    "iso-country": "^3.0.0",
    "node-fetch": "^3.2.10",
    "pg": "^8.11.0",
    "proxy-check": "^1.0.8",
    "qs": "^6.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/node": "^18.7.23",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^4.8.3"
  }
}
